# ─────────────────────────────────────────────────────────────
# Castor — Environment Variables Example
# Copy this file to .env in each app directory and fill in values.
# ─────────────────────────────────────────────────────────────

# Cross-app URLs (used by the shared Navbar in @castor/ui)
# Dev:  defaults are localhost ports — these vars are optional locally
# Prod: set these to the real production domains for each app

NEXT_PUBLIC_SERVICES_URL=http://localhost:3002
NEXT_PUBLIC_ECOMMERCE_URL=http://localhost:3005
NEXT_PUBLIC_INSTITUTE_URL=http://localhost:3000
NEXT_PUBLIC_TRANSPORT_URL=http://localhost:3003
NEXT_PUBLIC_WEB_URL=http://localhost:3004

# Production examples (uncomment and update when deploying):
# NEXT_PUBLIC_SERVICES_URL=https://castorhomenursing.com
# NEXT_PUBLIC_ECOMMERCE_URL=https://castorecommerce.com
# NEXT_PUBLIC_INSTITUTE_URL=https://castorhealthinstitute.com
# NEXT_PUBLIC_TRANSPORT_URL=https://castormedicaltransport.com
# NEXT_PUBLIC_WEB_URL=https://castor.com
